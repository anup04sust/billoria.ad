############################################
# Billoria root .gitignore
# Shared repo structure:
# /application-wiki
# /cmsapi
# /docs
# /frontendapp
# /scraper
############################################

############################
# OS files
############################
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.directory
.Trash-*

############################
# Editor / IDE
############################
.vscode/
.idea/
*.iml
*.ipr
*.iws
*.code-workspace
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~
.\#*
\#*\#

############################
# Logs / temp / caches
############################
*.log
logs/
*.tmp
*.temp
*.cache
.cache/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

############################
# Environment / secrets
############################
.env
.env.*
!.env.example
!.env.sample
!.env.template

**/.env
**/.env.*
!**/.env.example
!**/.env.sample
!**/.env.template

############################
# Security-sensitive files
############################
*.pem
*.key
*.crt
*.cert
*.p12
id_rsa
id_rsa.pub

############################
# Archives / dumps / backups
############################
*.sql
*.sql.gz
*.sql.zip
*.bak
*.backup
backup/
backups/
dumps/

############################
# Node / JS shared
############################
node_modules/
.pnpm-store/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz
coverage/
.nyc_output/
*.tsbuildinfo

########################################
# cmsapi (Drupal backend)
########################################

# Composer dependencies
/cmsapi/vendor/

# Composer-managed Drupal directories
/cmsapi/web/core/
/cmsapi/web/modules/contrib/
/cmsapi/web/themes/contrib/
/cmsapi/web/profiles/contrib/
/cmsapi/web/libraries/

# Uploaded / generated site files
/cmsapi/web/sites/*/files/
/cmsapi/web/sites/*/private/
/cmsapi/web/sites/simpletest/

# Local-only Drupal config
/cmsapi/web/sites/*/settings.local.php
/cmsapi/web/sites/*/services.local.yml

# Drush local/contrib
/cmsapi/drush/contrib/
/cmsapi/drush/sites/

# Local import/export data only
/cmsapi/*.csv
/cmsapi/*.xlsx

# Project-specific secret file
/cmsapi/d11Config/billoria_notifications.firebase.yml

########################################
# frontendapp (Next.js frontend)
########################################
/frontendapp/node_modules/
/frontendapp/.next/
/frontendapp/out/
/frontendapp/build/
/frontendapp/dist/

# Next local env files
/frontendapp/.env.local
/frontendapp/.env.development.local
/frontendapp/.env.production.local
/frontendapp/.env.test.local

########################################
# scraper
########################################

# Ignore generated/local scraper output,
# but keep docs if needed
/scraper/node_modules/
/scraper/.env
/scraper/.env.*
/scraper/output/
/scraper/tmp/
/scraper/cache/

########################################
# docs / wiki generated output
########################################

# Keep source docs tracked.
# Ignore only generated builds if they appear.
/docs/_build/
/docs/.doctrees/
/application-wiki/_build/
/application-wiki/.doctrees/

########################################
# Root local-only helper notes
########################################
PROJECT_NOTES.md
TODO.md
SCRATCH.md

########################################
# Optional local scripts/output
########################################
*.pid
/application-wiki