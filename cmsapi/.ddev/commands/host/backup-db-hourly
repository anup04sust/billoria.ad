#!/bin/bash

## Description: Create hourly database backup if DDEV is running
## Usage: backup-db-hourly
## Example: "ddev backup-db-hourly"

# Check if DDEV project is running
if ! ddev status 2>/dev/null | grep -q "OK"; then
    echo "DDEV is not running. Skipping backup."
    exit 0
fi

# Generate timestamp for backup name
TIMESTAMP=$(date +"%Y%m%d_%H%M")
BACKUP_NAME="auto_hourly_${TIMESTAMP}"

# Create snapshot
echo "Creating database snapshot: ${BACKUP_NAME}"
ddev snapshot --name="${BACKUP_NAME}"

# Keep only the last 24 hourly backups (last 24 hours)
# List snapshots and count auto_hourly_ backups
SNAPSHOT_COUNT=$(ddev snapshot --list 2>/dev/null | grep -c "auto_hourly_" || echo 0)

if [ "$SNAPSHOT_COUNT" -gt 24 ]; then
    echo "Found ${SNAPSHOT_COUNT} auto backups. Cleaning up old backups..."
    # Get list of auto_hourly snapshots sorted by date, keep last 24
    ddev snapshot --list 2>/dev/null | grep "auto_hourly_" | head -n -24 | while read -r line; do
        # Extract snapshot name (first field)
        SNAPSHOT_NAME=$(echo "$line" | awk '{print $1}')
        if [ -n "$SNAPSHOT_NAME" ]; then
            echo "Removing old snapshot: ${SNAPSHOT_NAME}"
            # Note: DDEV doesn't have a direct delete command, so we'll manually remove from .ddev/db_snapshots
            rm -rf ".ddev/db_snapshots/${SNAPSHOT_NAME}"* 2>/dev/null || true
        fi
    done
fi

echo "Hourly backup completed: ${BACKUP_NAME}"
