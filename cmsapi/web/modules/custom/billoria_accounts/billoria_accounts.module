<?php

/**
 * @file
 * Billoria Onboarding module hooks and mail implementation.
 */

use Drupal\Core\Routing\RouteMatchInterface;

/**
 * Implements hook_help().
 */
function billoria_accounts_help($route_name, RouteMatchInterface $route_match) {
  switch ($route_name) {
    case 'help.page.billoria_accounts':
      return '<p>' . t('User registration and onboarding system for Brands, Agencies, and Billboard Owners.') . '</p>';
  }
}

/**
 * Implements hook_mail().
 */
function billoria_accounts_mail($key, &$message, $params) {
  switch ($key) {
    case 'verify_email':
      $message['subject'] = $params['subject'];
      $message['body'][] = $params['body'];
      $message['headers']['Content-Type'] = 'text/plain; charset=UTF-8;';
      break;

    case 'verify_phone':
      $message['subject'] = $params['subject'];
      $message['body'][] = $params['body'];
      break;

    case 'organization_approved':
      $message['subject'] = $params['subject'];
      $message['body'][] = $params['body'];
      break;

    case 'organization_rejected':
      $message['subject'] = $params['subject'];
      $message['body'][] = $params['body'];
      break;
  }
}

/**
 * Implements hook_user_login().
 *
 * Note: Post-login redirects are handled by the Next.js frontend.
 * This hook intentionally does nothing for headless/API logins.
 */
function billoria_accounts_user_login($account) {
  // Redirect logic removed — Next.js frontend handles all post-login routing.
}
